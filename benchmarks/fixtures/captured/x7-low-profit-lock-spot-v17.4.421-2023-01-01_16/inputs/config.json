{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "strategy": "NostalgiaForInfinityX7",
  "test_x7_profile_enabled": true,
  "test_x7_profile_slow_seconds": 0.0,
  "test_x7_entry_line_profile_enabled": false,
  "test_x7_entry_line_profile_top_n": 20,
  "test_x7_informative_cache_enabled": true,
  "test_x7_parallel_analyze_workers": 1,
  "test_x7_skip_spot_short_entry_calc": true,
  "test_x7_btc_cache_enabled": true,
  "max_open_trades": 1,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",
  "dry_run": true,
  "dry_run_wallet": 1000,
  "cancel_open_orders_on_exit": false,
  "trading_mode": "spot",
  "margin_mode": "",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": [
      "BTC/USDT"
    ],
    "pair_blacklist": [
      ".*UP/USDT",
      ".*DOWN/USDT",
      ".*BULL/USDT",
      ".*BEAR/USDT",
      ".*3L/USDT",
      ".*3S/USDT",
      ".*5L/USDT",
      ".*5S/USDT"
    ]
  },
  "pairlists": [
    {
      "method": "StaticPairList",
      "allow_inactive": true
    }
  ],
  "telegram": {
    "enabled": false,
    "token": "",
    "chat_id": ""
  },
  "bot_name": "freqtrade",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  },
  "enable_protections": true
}
