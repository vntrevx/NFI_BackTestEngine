{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vntrevx/NFI_BackTestEngine/schemas/certification-report-v1.schema.json",
  "title": "NFI Backtest Engine certification report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_at",
    "fixture",
    "verification_level",
    "repetitions",
    "status",
    "release_certified",
    "claim_scope",
    "gates",
    "state_probes",
    "measurements",
    "environment",
    "performance_report"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "manifest_sha256"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "manifest_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "verification_level": {
      "const": "quick+full-probes"
    },
    "repetitions": {
      "type": "integer",
      "minimum": 3
    },
    "status": {
      "enum": ["certified", "failed"]
    },
    "release_certified": {
      "type": "boolean"
    },
    "claim_scope": {
      "type": "object"
    },
    "gates": {
      "type": "object",
      "required": ["parity", "speed", "memory", "state_probes"]
    },
    "state_probes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fixture_id",
          "manifest_sha256",
          "complete",
          "trade_surface_equal",
          "full_state_equal",
          "performance_report"
        ],
        "properties": {
          "fixture_id": {"type": "string", "minLength": 1},
          "manifest_sha256": {"$ref": "#/$defs/sha256"},
          "complete": {"type": "boolean"},
          "trade_surface_equal": {"type": "boolean"},
          "full_state_equal": {"type": "boolean"},
          "performance_report": {"$ref": "#/$defs/artifact"}
        }
      }
    },
    "measurements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine_wall_time_median_seconds",
        "reference_wall_time_median_seconds",
        "observed_speedup",
        "engine_peak_rss_bytes",
        "reference_peak_rss_bytes"
      ],
      "properties": {
        "engine_wall_time_median_seconds": {"type": "number", "exclusiveMinimum": 0},
        "reference_wall_time_median_seconds": {"type": "number", "exclusiveMinimum": 0},
        "observed_speedup": {"type": "number", "minimum": 0},
        "engine_peak_rss_bytes": {"type": "integer", "minimum": 0},
        "reference_peak_rss_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hardware", "execution_profile", "engine_build"],
      "properties": {
        "hardware": {"type": "object"},
        "execution_profile": {
          "type": ["object", "null"]
        },
        "engine_build": {"type": "object"}
      }
    },
    "performance_report": {
      "$ref": "#/$defs/artifact"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
