{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nfi.local/schemas/trade-surface-v1.json",
  "title": "NFI exact normalized trade surface",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trades"],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "trades": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trade"
      }
    }
  },
  "$defs": {
    "decimal": {
      "type": "string",
      "pattern": "^-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$"
    },
    "nullable_decimal": {
      "oneOf": [
        {
          "$ref": "#/$defs/decimal"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullable_string": {
      "type": ["string", "null"]
    },
    "order": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "side",
        "is_entry",
        "filled_timestamp_ms",
        "amount",
        "price",
        "cost",
        "tag"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "side": {
          "enum": ["buy", "sell"]
        },
        "is_entry": {
          "type": "boolean"
        },
        "filled_timestamp_ms": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "amount": {
          "$ref": "#/$defs/decimal"
        },
        "price": {
          "$ref": "#/$defs/nullable_decimal"
        },
        "cost": {
          "$ref": "#/$defs/nullable_decimal"
        },
        "tag": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "fees": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_rate",
        "open_cost",
        "open_currency",
        "close_rate",
        "close_cost",
        "close_currency",
        "funding"
      ],
      "properties": {
        "open_rate": {
          "$ref": "#/$defs/decimal"
        },
        "open_cost": {
          "$ref": "#/$defs/nullable_decimal"
        },
        "open_currency": {
          "$ref": "#/$defs/nullable_string"
        },
        "close_rate": {
          "$ref": "#/$defs/decimal"
        },
        "close_cost": {
          "$ref": "#/$defs/nullable_decimal"
        },
        "close_currency": {
          "$ref": "#/$defs/nullable_string"
        },
        "funding": {
          "$ref": "#/$defs/nullable_decimal"
        }
      }
    },
    "profit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["absolute", "ratio"],
      "properties": {
        "absolute": {
          "$ref": "#/$defs/decimal"
        },
        "ratio": {
          "$ref": "#/$defs/decimal"
        }
      }
    },
    "trade": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "pair",
        "direction",
        "open_timestamp_ms",
        "close_timestamp_ms",
        "open_rate",
        "close_rate",
        "amount",
        "stake_amount",
        "max_stake_amount",
        "leverage",
        "entry_tag",
        "exit_reason",
        "fees",
        "profit",
        "liquidation_price",
        "initial_stop_loss",
        "stop_loss",
        "orders"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "pair": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "enum": ["long", "short"]
        },
        "open_timestamp_ms": {
          "type": "integer",
          "minimum": 0
        },
        "close_timestamp_ms": {
          "type": "integer",
          "minimum": 0
        },
        "open_rate": {
          "$ref": "#/$defs/decimal"
        },
        "close_rate": {
          "$ref": "#/$defs/decimal"
        },
        "amount": {
          "$ref": "#/$defs/decimal"
        },
        "stake_amount": {
          "$ref": "#/$defs/decimal"
        },
        "max_stake_amount": {
          "$ref": "#/$defs/decimal"
        },
        "leverage": {
          "$ref": "#/$defs/decimal"
        },
        "entry_tag": {
          "$ref": "#/$defs/nullable_string"
        },
        "exit_reason": {
          "type": "string",
          "minLength": 1
        },
        "fees": {
          "$ref": "#/$defs/fees"
        },
        "profit": {
          "$ref": "#/$defs/profit"
        },
        "liquidation_price": {
          "$ref": "#/$defs/nullable_decimal"
        },
        "initial_stop_loss": {
          "$ref": "#/$defs/nullable_decimal"
        },
        "stop_loss": {
          "$ref": "#/$defs/nullable_decimal"
        },
        "orders": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/order"
          }
        }
      }
    }
  }
}
